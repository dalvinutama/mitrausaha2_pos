```mermaid
graph TB
  %% Actors
  Owner((Owner))
  Admin((Admin))
  Gudang((Gudang))
  Penjualan((Penjualan))
  Pengiriman((Pengiriman))
  Kasir((Kasir))

  %% ===== Use Cases =====

  subgraph Autentikasi
    UC1[Login / Logout]
  end

  subgraph Dashboard
    UC2[Lihat Dashboard Analitik]
  end

  subgraph "Manajemen Produk"
    UC3[Lihat Daftar Produk]
    UC4[Tambah / Edit / Hapus Produk]
  end

  subgraph "Manajemen Kategori"
    UC5[Lihat Kategori]
    UC6[Tambah / Edit / Hapus Kategori]
  end

  subgraph "Manajemen Supplier"
    UC7[Lihat Supplier]
    UC8[Tambah / Edit / Hapus Supplier]
  end

  subgraph "Stok Masuk"
    UC9[Input Stok Masuk]
  end

  subgraph "Stok Keluar"
    UC10[Input Stok Keluar / Penjualan]
  end

  subgraph "Purchase Order"
    UC11[Buat Draft PO]
    UC12[Approve / Tolak PO]
    UC13[Lihat Daftar PO]
  end

  subgraph "Stock Opname"
    UC14[Buat Draft Opname]
    UC15[Approve / Reject Opname]
    UC16[Lihat Riwayat Opname]
  end

  subgraph "Pembayaran"
    UC17[Catat Pembayaran]
    UC18[Lihat Pembayaran]
  end

  subgraph "Pengiriman"
    UC19[Update Status Pengiriman]
    UC20[Lihat Pengiriman]
